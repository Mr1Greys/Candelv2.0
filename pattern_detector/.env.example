# Telegram (required for signals)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Market data (optional — defaults work on Vercel)
BINANCE_REST_URL=https://data-api.binance.vision/api/v3/klines
FLAG_TIMEFRAMES=1h,4h
COMBO_FLAG_TIMEFRAME=4h
ENGULFING_TIMEFRAME=1d
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# Engulfing thresholds (optional)
MIN_CONFIDENCE=0.5
ENGULFING_PREV_CANDLES_MIN=1
ENGULFING_PREV_CANDLES_MAX=3
MIN_ENGULFING_BODY_POINTS=300

# Vercel Cron (set automatically on Vercel when Cron Jobs are enabled)
# CRON_SECRET=

# Vercel KV / Upstash (auto-filled when KV storage is linked)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Matplotlib cache (required on Vercel)
# MPLCONFIGDIR=/tmp
